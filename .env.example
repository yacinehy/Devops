# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env — il est dans .gitignore

# Connexion PostgreSQL (utilisé par Flask et par docker-compose pour créer la base)
DB_HOST=db              # nom du service docker-compose = hostname réseau interne
DB_PORT=5432
DB_NAME=flaskdb
DB_USER=flaskuser
DB_PASSWORD=changeme    # à remplacer par un mot de passe fort en prod

# PostgreSQL attend ces variables pour initialiser le conteneur au premier démarrage
POSTGRES_DB=flaskdb
POSTGRES_USER=flaskuser
POSTGRES_PASSWORD=changeme
